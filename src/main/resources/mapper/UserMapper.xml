<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.UserDao">
    <select id="findById" resultType="com.model.User">
        select `id`,`name`,`password` from user
        where id = #{id}
    </select>

    <select id="findByMap" resultType="com.model.User">
        select `id`,`name`,`password` from user
        <where>
            <if test="id != null and id != ''">
                and id = #{id}
            </if>
            <if test="name != null and name != ''">
                and name = #{name}
            </if>
            <if test="password != null and password != ''">
                and password = #{password}
            </if>
        </where>
    </select>

    <select id="list" resultType="com.model.User">
        select `id`,`name`,`password` from user
        <where>
            <if test="id != null and id != ''">
                and id =
                #{id}
            </if>
            <if test="name != null and name != ''">
                and name =
                #{name}
            </if>
            <if test="password != null and password != ''">
                and password =
                #{password}
            </if>
        </where>
    </select>

    <insert id="save" parameterType="com.model.User" useGeneratedKeys="true" keyProperty="id">
        insert into user(
        <trim suffixOverrides=",">
            <if test="name != null">
                `name`,
            </if>
            <if test="password != null">
                `password`
            </if>
        </trim>
        )
        values (
        <trim suffixOverrides=",">
            <if test="name != null">
                #{name},
            </if>
            <if test="password != null">
                #{password}
            </if>
        </trim>
        )
    </insert>

    <update id="update" parameterType="com.model.User">
        update user
        <set>
            <if test="name != null">
                `name` = #{name}
                ,
            </if>
            <if test="password != null">
                `password` = #{password}
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete
        from user
        where id = #{id}
    </delete>
</mapper>