<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ImportLogDao">

    <select id="findById" resultType="com.model.ImportLog">
        select `id`,
               `student_no`,
               `sex`,
               `school_code`,
               `money`,
               `time`,
               `station`,
               `create_time`
        from import_log
        where id = #{id}
    </select>
    <select id="getImportTime" resultType="java.lang.String">
        select distinct `create_time`
        from import_log
    </select>

    <select id="findByMap" resultType="com.model.ImportLog">
        select `id`,`student_no`,`sex`,`school_code`,`money`,`time`,`station`,`create_time` from import_log
        <where>
            <if test="id != null and id != ''">
                and id = #{id}
            </if>
            <if test="studentNo != null and studentNo != ''">
                and student_no = #{studentNo}
            </if>
            <if test="sex != null and sex != ''">
                and sex = #{sex}
            </if>
            <if test="schoolCode != null and schoolCode != ''">
                and school_code = #{schoolCode}
            </if>
            <if test="money != null and money != ''">
                and money = #{money}
            </if>
            <if test="time != null and time != ''">
                and time = #{time}
            </if>
            <if test="station != null and station != ''">
                and station = #{station}
            </if>
            <if test="createTime != null and createTime != ''">
                and create_time = #{createTime}
            </if>
        </where>
    </select>

    <select id="list" resultType="com.model.ImportLog">
        select `id`,`student_no`,`sex`,`school_code`,`money`,`time`,`station`,`create_time` from import_log
        <where>
            <if test="id != null and id != ''">and id =
                #{id}
            </if>
            <if test="studentNo != null and studentNo != ''">and student_no =
                #{studentNo}
            </if>
            <if test="sex != null and sex != ''">and sex =
                #{sex}
            </if>
            <if test="schoolCode != null and schoolCode != ''">and school_code =
                #{schoolCode}
            </if>
            <if test="money != null and money != ''">and money =
                #{money}
            </if>
            <if test="time != null and time != ''">and time =
                #{time}
            </if>
            <if test="station != null and station != ''">and station =
                #{station}
            </if>
            <if test="createTime != null and createTime != ''">and create_time =
                #{createTime}
            </if>
            <if test="grade != null and grade != ''">and left(student_no, 4) =
                #{grade}
            </if>
            <if test="endTime != null and endTime != ''">
                and DATE_SUB(DATE(#{endTime}), INTERVAL 7 DAY) &lt;= date(`time`)
                <!--                and (DATE(time) between DATE(#{startTime}) and DATE(#{endTime}))-->
            </if>

        </where>
        order by time
    </select>

    <insert id="save" parameterType="com.model.ImportLog" useGeneratedKeys="true" keyProperty="id">
        insert into import_log(
        <trim suffixOverrides=",">
            <if test="studentNo != null">`student_no`,</if>
            <if test="sex != null">`sex`,</if>
            <if test="schoolCode != null">`school_code`,</if>
            <if test="money != null">`money`,</if>
            <if test="time != null">`time`,</if>
            <if test="station != null">`station`,</if>
            <if test="createTime != null">`create_time`</if>
        </trim>
        )
        values (
        <trim suffixOverrides=",">
            <if test="studentNo != null">#{studentNo},</if>
            <if test="sex != null">#{sex},</if>
            <if test="schoolCode != null">#{schoolCode},</if>
            <if test="money != null">#{money},</if>
            <if test="time != null">#{time},</if>
            <if test="station != null">#{station},</if>
            <if test="createTime != null">#{createTime}</if>
        </trim>
        )
    </insert>

    <insert id="bitchSave">
        insert into import_log(
        `student_no`,
        `sex`,
        `school_code`,
        `money`,
        `time`,
        `station`,
        `create_time`
        )
        values
        <foreach collection="importLogList" item="importLog" separator=",">
            (
            #{importLog.studentNo},
            #{importLog.sex},
            #{importLog.schoolCode},
            #{importLog.money},
            #{importLog.time},
            #{importLog.station},
            default
            )
        </foreach>
    </insert>

    <update id="update" parameterType="com.model.ImportLog">
        update import_log
        <set>
            <if test="studentNo != null">`student_no` = #{studentNo},
            </if>
            <if test="sex != null">`sex` = #{sex},
            </if>
            <if test="schoolCode != null">`school_code` = #{schoolCode},
            </if>
            <if test="money != null">`money` = #{money},
            </if>
            <if test="time != null">`time` = #{time},
            </if>
            <if test="station != null">`station` = #{station},
            </if>
            <if test="createTime != null">`create_time` = #{createTime}
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete
        from import_log
        where id = #{id}
    </delete>

</mapper>